# Real trading needs a Polygon signing key. Keep this file private.
POLYMARKET_PRIVATE_KEY=
# Optional: needed for proxy/deposit-wallet accounts.
POLYMARKET_FUNDER_ADDRESS=
# 0=EOA, 1=POLY_PROXY, 2=POLY_GNOSIS_SAFE, 3=POLY_1271 deposit wallet.
POLYMARKET_SIGNATURE_TYPE=0
# Optional: provide existing L2 credentials instead of deriving them on startup.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Local state containing only order IDs and quote metadata (never secrets).
POLYMARKET_ORDER_JOURNAL_PATH=.poly-mm-orders.json
# Required to enable the loopback-only web console. Username is always "admin".
POLYMARKET_CONSOLE_PASSWORD=
